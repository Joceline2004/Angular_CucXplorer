{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "rootDir": "./src",
    "types": [
      "node"
    ]
  },
  "files": [
    "src/main.ts" // Asegúrate de que la ruta sea correcta hacia tu main.ts
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}